<Page x:Class="UnoWebTemplate.Client.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoWebTemplate.Client"
      xmlns:widgets="using:UnoWebTemplate.Client.Widgets"
      Background="#0F172A"
      SizeChanged="Page_SizeChanged">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <Grid HorizontalAlignment="Center" MaxWidth="1000" Margin="0,10">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="20">
                
                <!-- Header Title Section -->
                <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Uno Platform Interactive Showcase"
                               Foreground="White"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="Demonstrating multi-platform real-time vector graphics, 3D composition tilts, and persistent SignalR connectivity."
                               Foreground="#94A3B8"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />

                    <HyperlinkButton NavigateUri="https://github.com/jav76/UnoWebTemplate"
                                     HorizontalAlignment="Center"
                                     Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <!-- GitHub Icon -->
                            <Path Fill="White"
                                  Data="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                                  Stretch="Uniform"
                                  Height="20" Width="20"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="View on GitHub"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </HyperlinkButton>
                </StackPanel>

                <!-- Responsive Grid Dashboard -->
                <Grid x:Name="DashboardGrid" Grid.Row="1" HorizontalAlignment="Stretch">
                    <!-- Column/Row definitions and element placements are calculated responsively in MainPage.xaml.cs -->
                    <widgets:ConnectivityWidget x:Name="ConnectivityCard" />
                    <widgets:TiltCardWidget x:Name="TiltCard" />
                    <widgets:ParticleSandboxWidget x:Name="ParticleCard" />
                </Grid>

                <!-- Infrastructure Overview & Diagnostics Card -->
                <Border Grid.Row="2"
                        Background="#CC111827"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,10,0,0">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="20">
                        <!-- Card Header -->
                        <TextBlock Grid.Row="0"
                                   Text="Template Architecture &amp; Infrastructure"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold" />

                        <!-- Content Stack -->
                        <!-- Content Stack -->
                        <Grid x:Name="InfoGrid" Grid.Row="1" HorizontalAlignment="Stretch">
                            
                            <!-- Tech Stack Info Panel -->
                            <StackPanel x:Name="TechStackPanel" Spacing="12" Width="420" HorizontalAlignment="Left">
                                <TextBlock Text="Core Technology Stack"
                                           Foreground="#8B5CF6"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="• Frontend:" Foreground="#3B82F6" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Uno Single-Project (WinUI 3 wrapper) compiled to WASM &amp; Skia Desktop." Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="• Style:" Foreground="#3B82F6" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Tailwind CSS v4 with Node-Free MSBuild CLI auto-downloader." Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="• Backend:" Foreground="#3B82F6" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="ASP.NET Core Web API hosting the WASM client static assets." Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="• Database:" Foreground="#3B82F6" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Entity Framework Core (SQLite local, migrations apply at startup)." Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>

                            <!-- Verification Diagnostics Panel -->
                            <StackPanel x:Name="DiagnosticsPanel" Spacing="12" HorizontalAlignment="Stretch">
                                <TextBlock Text="Diagnostics &amp; Status Validation"
                                           Foreground="#10B981"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                
                                <TextBlock Text="Verify client-to-server static API routing and SignalR persistent connection states using these verification links:"
                                           Foreground="#94A3B8"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Padding="2, 2, 2, 2" />

                                <!-- Diagnostics Buttons Stack -->
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,5,0,0">
                                    <Button Content="Check Status (HTTP)"
                                            Background="#3B82F6"
                                            Foreground="White"
                                            CornerRadius="6"
                                            Padding="15,8"
                                            Click="StatusButtonHttp_Click" />
                                    <Button Content="Check Status (SignalR)"
                                            Background="#8B5CF6"
                                            Foreground="White"
                                            CornerRadius="6"
                                            Padding="15,8"
                                            Click="StatusButtonSignalR_Click" />
                                </StackPanel>

                                <!-- Status Output console -->
                                <TextBlock x:Name="StatusText"
                                           Text="Status Output Console ready."
                                           Foreground="#94A3B8"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
