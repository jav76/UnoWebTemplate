<Page x:Class="UnoWebTemplate.Client.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoWebTemplate.Client"
      Background="#0F172A">

    <ScrollViewer>
        <Grid>
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="AdaptiveStates">
                    <VisualState x:Name="NarrowState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ButtonStackPanel.Orientation" Value="Vertical" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="600" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ButtonStackPanel.Orientation" Value="Horizontal" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Padding="20">
                <!-- Title -->
                <TextBlock Text="Welcome to UnoWebTemplate"
                           Foreground="White"
                           FontSize="36"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords" />

                <!-- Description -->
                <TextBlock Text="Multi-targeted Uno WebAssembly client hosting on ASP.NET Core with Tailwind CSS v4."
                           Foreground="#94A3B8"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords" />

                <StackPanel x:Name="ButtonStackPanel" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                    <!-- HTTP Quick Status Button -->
                    <Button Content="Check Backend Status (HTTP)"
                            Background="#3B82F6"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="6"
                            Click="StatusButtonHttp_Click"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" />

                    <!-- SignalR Quick Status Button -->
                    <Button Content="Check Backend Status (SignalR)"
                            Background="#8B5CF6"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="6"
                            Click="StatusButtonSignalR_Click"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" />
                </StackPanel>

                <!-- Status Output -->
                <TextBlock x:Name="StatusText"
                           Foreground="#10B981"
                           FontSize="14"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
