<UserControl x:Class="UnoWebTemplate.Client.Widgets.ConnectivityWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <UserControl.Resources>
        <!-- Storyboard for pulsing glowing indicator -->
        <Storyboard x:Name="PulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseCircleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="2.5"
                             Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="PulseCircleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="2.5"
                             Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="PulseCircle"
                             Storyboard.TargetProperty="Opacity"
                             From="0.8" To="0.0"
                             Duration="0:0:1.5" />
        </Storyboard>
    </UserControl.Resources>

    <Border Background="#1E293B"
            BorderBrush="#4D3B82F6"
            BorderThickness="1.5"
            CornerRadius="12"
            Padding="20"
            Margin="0,0,0,16">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="15">
            <!-- Header Title -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                <TextBlock Text="Backend Connection"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold" />
            </StackPanel>

            <!-- Status Indicator Light -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <Grid Width="24" Height="24">
                    <!-- Glowing pulsing outer ring -->
                    <Ellipse x:Name="PulseCircle"
                             Width="12"
                             Height="12"
                             Fill="#10B981"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="PulseCircleTransform" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <!-- Solid inner indicator -->
                    <Ellipse x:Name="SolidCircle"
                             Width="10"
                             Height="10"
                             Fill="#10B981"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
                <TextBlock x:Name="IndicatorText"
                           Text="CONNECTED"
                           Foreground="#10B981"
                           FontSize="12"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Auto Ping Toggle -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <TextBlock Text="Auto-Ping (2s):"
                           Foreground="#94A3B8"
                           FontSize="13"
                           VerticalAlignment="Center" />
                <ToggleSwitch x:Name="AutoPingToggle"
                              OnContent=""
                              OffContent=""
                              IsOn="False"
                              Toggled="AutoPingToggle_Toggled"
                              VerticalAlignment="Center" />
            </StackPanel>

            <!-- Real-time Sparkline Graph Area -->
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Height="100" Margin="0,5">
                <!-- Background grid lines for the chart -->
                <Grid BorderBrush="#1AFFFFFF" BorderThickness="0,1" Height="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1" />
                    <Border Grid.Row="1" BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1" />
                </Grid>

                <!-- Vector Polyline representing latencies -->
                <Canvas x:Name="GraphCanvas" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <!-- Smooth blue line -->
                    <Polyline x:Name="LatencyLine"
                              Stroke="#3B82F6"
                              StrokeThickness="2.5"
                              StrokeLineJoin="Round" />
                </Canvas>

                <!-- Latency stats overlay -->
                <TextBlock x:Name="MinMaxText"
                           Text="No data yet"
                           Foreground="#64748B"
                           FontSize="11"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Left"
                           Margin="5,5,0,0" />
            </Grid>

            <!-- Buttons -->
            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="HTTP Ping"
                        Background="#3B82F6"
                        Foreground="White"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,10"
                        Click="HttpPingButton_Click" />
                <Button Grid.Column="1"
                        Content="SignalR Ping"
                        Background="#8B5CF6"
                        Foreground="White"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,10"
                        Click="SignalRPingButton_Click" />
            </Grid>

            <!-- Output status console text -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="#0F172A"
                    CornerRadius="6"
                    Padding="10"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="40">
                    <TextBlock x:Name="ConsoleOutput"
                               Text="Console ready. Click Ping or turn on Auto-Ping."
                               Foreground="#94A3B8"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
