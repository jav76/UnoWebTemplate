<UserControl x:Class="UnoWebTemplate.Client.Widgets.ParticleSandboxWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="500">

    <Border Background="#1E293B"
            BorderBrush="#4D10B981"
            BorderThickness="1.5"
            CornerRadius="12"
            Padding="20"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        
        <Grid RowDefinitions="Auto,*" RowSpacing="15">
            <!-- Header section -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Particle Playground"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="Hover to attract | Click to burst"
                               Foreground="#94A3B8"
                               FontSize="12" />
                </StackPanel>
                
                <!-- Live count indicator -->
                <Border Grid.Column="1"
                        Background="#1A10B981"
                        BorderBrush="#8010B981"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ParticleCountText"
                               Text="Particles: 0"
                               Foreground="#10B981"
                               FontSize="11"
                               FontWeight="Bold" />
                </Border>
            </Grid>

            <!-- Interactive Canvas Area -->
            <!-- We wrap in a Grid with Background="Transparent" to capture Pointer events easily, and set ClipToBounds -->
            <Border Grid.Row="1"
                    Background="#0F172A"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                
                <Grid Background="Transparent"
                      CornerRadius="8"
                      PointerPressed="Canvas_PointerPressed"
                      PointerMoved="Canvas_PointerMoved"
                      PointerEntered="Canvas_PointerEntered"
                      PointerExited="Canvas_PointerExited">
                    
                    <Canvas x:Name="ParticleCanvas"
                            Background="Transparent"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
