<UserControl x:Class="UnoWebTemplate.Client.Widgets.TiltCardWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="250"
             d:DesignWidth="400">

    <Grid Background="Transparent"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Padding="10">
        
        <!-- Interactive Card Container -->
        <Grid x:Name="CardRoot"
              Width="320"
              Height="190"
              Background="#CC111827"
              BorderBrush="#808B5CF6"
              BorderThickness="1.5"
              CornerRadius="16"
              PointerMoved="CardRoot_PointerMoved"
              PointerEntered="CardRoot_PointerEntered"
              PointerExited="CardRoot_PointerExited"
              PointerPressed="CardRoot_PointerPressed"
              PointerReleased="CardRoot_PointerReleased"
              PointerCaptureLost="CardRoot_PointerCaptureLost"
              RenderTransformOrigin="0.5,0.5">

            <!-- 2.5D Skew/Scale Render Transform -->
            <Grid.RenderTransform>
                <CompositeTransform x:Name="CardTransform" ScaleX="1.0" ScaleY="1.0" SkewX="0" SkewY="0" />
            </Grid.RenderTransform>

            <!-- Card Design Elements -->
            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top Header: Chip and Card Brand -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <!-- Futuristic gold chip -->
                    <Border Grid.Column="0"
                            Width="38"
                            Height="28"
                            Background="#E0A78DF5"
                            BorderBrush="#FFC084FC"
                            BorderThickness="1"
                            CornerRadius="6"
                            HorizontalAlignment="Left">
                        <!-- Tiny grid lines on chip -->
                        <Grid BorderBrush="#40000000" BorderThickness="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#40000000" BorderThickness="0,0,1,0" />
                            <Border Grid.Column="1" BorderBrush="#40000000" BorderThickness="0,0,1,0" />
                        </Grid>
                    </Border>
                    <!-- Logo / Tech Name -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="UNO"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Black"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="3D"
                                   Foreground="#A855F7"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Center: Cardholder/Project Details -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Uno Platform Showcase"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="GPU-Accelerated WebGL/Skia"
                               Foreground="#94A3B8"
                               FontSize="11"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Bottom: Serial & Holographic Specs -->
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="MEMBER NAME"
                                   Foreground="#64748B"
                                   FontSize="8"
                                   FontWeight="Bold" />
                        <TextBlock Text="DEVELOPER PASS"
                                   Foreground="#C084FC"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                        <TextBlock Text="EXPIRES"
                                   Foreground="#64748B"
                                   FontSize="8"
                                   FontWeight="Bold" />
                        <TextBlock Text="12/29"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Holographic Sheen/Glare Overlay -->
            <Rectangle x:Name="SheenOverlay"
                       IsHitTestVisible="False"
                       Opacity="0"
                       RadiusX="16"
                       RadiusY="16">
                <Rectangle.Fill>
                    <LinearGradientBrush x:Name="SheenBrush" StartPoint="0.0,0.0" EndPoint="1.0,1.0">
                        <GradientStop Color="#00FFFFFF" Offset="0.0" />
                        <GradientStop Color="#1AFFFFFF" Offset="0.3" />
                        <GradientStop Color="#4D8BE9FD" Offset="0.5" />
                        <GradientStop Color="#1AFFFFFF" Offset="0.7" />
                        <GradientStop Color="#00FFFFFF" Offset="1.0" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Thin inner lighting highlight -->
            <Border BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    IsHitTestVisible="False" />
        </Grid>
    </Grid>
</UserControl>
